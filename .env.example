# Database
DB_PATH=./kanban.db

# Co-Pilot LLM (pick one provider)
# Option A: OpenRouter (recommended — access to many models)
#   Get a key at https://openrouter.ai/keys
COPILOT_DEFAULT_PROVIDER=openrouter
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=your-api-key-here
COPILOT_DEFAULT_MODEL=gpt-4o-mini

# Option B: OpenAI directly
#   Get a key at https://platform.openai.com/api-keys
#   Uncomment and replace the values above:
# OPENROUTER_BASE_URL=https://api.openai.com/v1
# OPENROUTER_API_KEY=sk-your-openai-key-here
# COPILOT_DEFAULT_MODEL=gpt-4o-mini

# Option C: Ollama (local, free, no API key needed)
#   Install from https://ollama.com then: ollama pull llama3.2:3b
# COPILOT_DEFAULT_PROVIDER=ollama
# COPILOT_DEFAULT_MODEL=llama3.2:3b

# Google Calendar (optional)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/calendar/callback

# Telegram daily brief (optional)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-user-id


# GitHub integration (optional — enables list_github_issues tool)
#   For public repos, GITHUB_TOKEN is optional but recommended to avoid rate limits.
#   Create a token at https://github.com/settings/tokens (read-only scope is enough)
GITHUB_REPO=owner/repo
GITHUB_TOKEN=
